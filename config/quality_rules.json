{
  "min_score": 40,
  "scoring": {
    "topic_relevance": {
      "max": 30,
      "description": "Tech/engineering topic relevance",
      "keywords": [
        "AI", "machine learning", "deep learning", "LLM", "GPT", "Claude",
        "cloud", "AWS", "GCP", "Azure", "kubernetes", "docker", "DevOps",
        "API", "REST", "GraphQL", "microservices", "serverless",
        "database", "SQL", "NoSQL", "PostgreSQL", "Redis", "MongoDB",
        "security", "cybersecurity", "vulnerability", "encryption",
        "web", "frontend", "backend", "fullstack", "React", "Next.js", "Vue",
        "mobile", "iOS", "Android", "Flutter", "React Native",
        "Python", "JavaScript", "TypeScript", "Rust", "Go", "Java", "C++",
        "open source", "GitHub", "git", "CI/CD", "automation",
        "startup", "SaaS", "infrastructure", "observability", "monitoring",
        "data engineering", "MLOps", "platform", "developer", "engineering",
        "programming", "software", "algorithm", "system design",
        "performance", "scaling", "distributed", "networking",
        "blockchain", "Web3", "edge computing", "IoT",
        "vibe coding", "no-code", "low-code", "prompt engineering"
      ]
    },
    "freshness": {
      "max": 20,
      "description": "Trend freshness",
      "hours_full_score": 24,
      "hours_zero_score": 168
    },
    "search_demand": {
      "max": 20,
      "description": "Search demand (Google Trends relative value)"
    },
    "source_trust": {
      "max": 15,
      "description": "Source trustworthiness",
      "levels": {
        "high": 15,
        "medium": 8,
        "low": 3
      },
      "high_sources": ["github.com", "official blog", "press release", "engineering blog"],
      "low_sources": ["twitter.com", "x.com", "reddit.com"]
    },
    "monetization": {
      "max": 15,
      "description": "Monetization potential",
      "keywords": ["tool", "app", "service", "product", "device", "subscription", "deal", "recommendation", "SaaS", "platform"]
    }
  },
  "discard_rules": [
    {
      "id": "no_topic_relevance",
      "description": "Not relevant to tech/engineering audience",
      "condition": "topic_relevance_score == 0"
    },
    {
      "id": "unverified_source",
      "description": "Unverified or unknown source",
      "condition": "source_trust_level == 'unknown'"
    },
    {
      "id": "duplicate_topic",
      "description": "80%+ similarity to previously published topic",
      "similarity_threshold": 0.8
    },
    {
      "id": "stale_trend",
      "description": "Trend older than 7 days (except evergreen)",
      "max_age_days": 7,
      "except_evergreen": true
    },
    {
      "id": "promotional",
      "description": "Clearly promotional/advertorial content",
      "keywords": ["sponsored", "advertisement", "paid promotion", "partner content", "AD"]
    },
    {
      "id": "clickbait",
      "description": "Clickbait-style topic",
      "patterns": ["you won't believe", "shocking", "insane", "mind-blowing", "game changer", "kills"]
    }
  ],
  "evergreen_keywords": [
    "guide", "tutorial", "how to", "how-to", "introduction", "basics",
    "getting started", "best practices", "cheat sheet", "deep dive",
    "explained", "fundamentals", "walkthrough", "crash course"
  ]
}
