GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=
BLOG_MAIN_ID=your-blogger-blog-id
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
# ─── Gemini API (required, for article generation) ──
GEMINI_API_KEY=your-gemini-api-key
# Gemini model selection (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Image mode (manual | request | auto)
#   manual  — Sends 1 prompt via Telegram at publish time (default)
#   request — Weekly batch of prompts via Telegram → user generates & sends back
#   auto    — OpenAI DALL-E API auto-generation (requires OPENAI_API_KEY, separate cost)
IMAGE_MODE=manual
# Auto mode only
OPENAI_API_KEY=
# Blog site URL (for Search Console indexing)
BLOG_SITE_URL=
